	EXP1_1=PB5,  EXP1_3=PA9,   EXP1_5=PA10, EXP1_7=PB8, EXP1_9=<GND>,
	EXP1_2=PA15, EXP1_4=<RST>, EXP1_6=PB9,  EXP1_8=PD6, EXP1_10=<5V>

[display]
lcd_type = st7920
cs_pin = PB8
sclk_pin = PB9
sid_pin = PD6
encoder_pins = ^PA10, ^PA9
click_pin = ^!PA15

[output_pin beeper]
pin = PB5

[bltouch]
sensor_pin = ^PC14
control_pin = PA1
x_offset = 1.2
y_offset = -41.8
samples = 2
speed = 2
z_offset = 2.475
probe_with_touch_mode = true

[safe_z_home]
home_xy_position = 117,117
speed = 50
z_hop = 10
z_hop_speed = 5

[bed_mesh]
speed = 80
horizontal_move_z = 5
mesh_min = 11, 6
mesh_max = 222, 192
probe_count = 10,10
mesh_pps = 2,2
fade_start = 1
fade_end = 10
fade_target = 0
algorithm = bicubic

[firmware_retraction]
retract_length = 2
retract_speed = 45
unretract_extra_length = 0
unretract_speed = 45
