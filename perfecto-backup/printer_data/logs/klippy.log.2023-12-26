y_offset = -41.8
samples = 2
speed = 2
z_offset = 2.475
probe_with_touch_mode = true

[safe_z_home]
home_xy_position = 117,117
speed = 50
z_hop = 10
z_hop_speed = 5

[bed_mesh]
speed = 80
horizontal_move_z = 5
mesh_min = 11, 6
mesh_max = 222, 192
probe_count = 10,10
mesh_pps = 2,2
fade_start = 1
fade_end = 10
fade_target = 0
algorithm = bicubic

[firmware_retraction]
retract_length = 2
retract_speed = 45
unretract_extra_length = 0
unretract_speed = 45

[gcode_macro update_git]
gcode = 
	RUN_SHELL_COMMAND CMD=update_git_script

[gcode_shell_command update_git_script]
command = bash /home/pi/klipper-backup/script.sh
timeout = 90.0
verbose = True
